// FlowPack Prisma Schema
// docs/db-schema.md 기반 단일 출처 (Single Source of Truth)
// ⚠️ 직접 수정 금지 — docs/change-proposals/ 제안서 작성 후 승인 필요

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enum ────────────────────────────────────────────────

enum PlanTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  USER
  ADMIN
}

enum ContentType {
  CAROUSEL
  BLOG
  VIDEO
  BULK
  URL_TO_POST
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  LINKEDIN
  NAVER_BLOG
  WORDPRESS
  THREADS
}

enum PublishStatus {
  PENDING
  SUCCESS
  FAILED
}

enum MediaType {
  IMAGE
  AUDIO
  DOCUMENT
}

// ─── User ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  plan          PlanTier  @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creditsUsed        Int       @default(0)
  creditsTotal       Int       @default(10)
  creditsResetAt     DateTime?
  notificationPrefs  String?   // JSON 직렬화된 알림 설정
  role               UserRole  @default(USER)    // 관리자 역할
  isBlocked          Boolean   @default(false)   // 계정 정지 여부

  accounts       Account[]
  sessions       Session[]
  contents       Content[]
  socialAccounts SocialAccount[]
  persona        Persona?
  subscriptions  Subscription[]
  paymentLogs    PaymentLog[]
  aiUsageLogs    AiUsageLog[]
  instructions   UserInstruction[]
  mediaFiles     MediaFile[]

  @@index([email])
  @@map("users")
}

// ─── Auth.js 테이블 ────────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Content ──────────────────────────────────────────────

model Content {
  id           String        @id @default(cuid())
  userId       String
  title        String
  type         ContentType
  status       ContentStatus @default(DRAFT)
  body         String?
  slides       String?
  thumbnailUrl String?
  aiPrompt     String?
  aiProvider   String?           // "openai", "anthropic", "google" 등
  aiModel      String?           // "gpt-4o", "claude-3-7-sonnet" 등
  aiLog        String?           // JSON: {messages, tokensUsed, duration, systemInstructions}
  tone         String?
  style        String?
  keywords     String?           // JSON 배열 ["키워드1", "키워드2"]
  industry     String?           // "tech", "education", "healthcare" 등
  viewCount    Int           @default(0)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishes PublishRecord[]
  images    ContentImage[]

  @@index([userId, status])
  @@index([userId, type])
  @@index([scheduledAt])
  @@map("contents")
}

model ContentImage {
  id        String   @id @default(cuid())
  contentId String
  url       String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_images")
}

// ─── Media File (미디어 라이브러리) ───────────────────────

model MediaFile {
  id        String    @id @default(cuid())
  userId    String
  name      String            // 원본 파일명
  url       String            // Vercel Blob CDN URL
  blobKey   String            // Blob pathname (삭제 시 사용)
  mimeType  String            // "image/jpeg", "audio/mpeg" 등
  mediaType MediaType
  size      Int               // bytes
  width     Int?              // 이미지 전용
  height    Int?              // 이미지 전용
  duration  Float?            // 오디오 전용 (초)
  alt       String?           // 대체 텍스트
  tags      String?           // JSON 배열 ["태그1","태그2"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mediaType])
  @@index([userId, createdAt])
  @@map("media_files")
}

// ─── Social Account ───────────────────────────────────────

model SocialAccount {
  id             String         @id @default(cuid())
  userId         String
  platform       SocialPlatform
  accountName    String
  accountId      String
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  isActive       Boolean        @default(true)
  connectedAt    DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishes PublishRecord[]

  @@unique([userId, platform])
  @@index([userId])
  @@map("social_accounts")
}

// ─── Publish Record ───────────────────────────────────────

model PublishRecord {
  id              String        @id @default(cuid())
  contentId       String
  socialAccountId String
  status          PublishStatus @default(PENDING)
  platformPostId  String?
  platformPostUrl String?
  errorMessage    String?
  clickCount      Int           @default(0)    // 리다이렉트 클릭 추적
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  content       Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([socialAccountId])
  @@map("publish_records")
}

// ─── Analytics ────────────────────────────────────────────

model Analytics {
  id           String         @id @default(cuid())
  contentId    String
  platform     SocialPlatform
  viewCount    Int            @default(0)
  likeCount    Int            @default(0)
  shareCount   Int            @default(0)
  commentCount Int            @default(0)
  recordedAt   DateTime       @default(now())

  @@index([contentId])
  @@index([recordedAt])
  @@map("analytics")
}

// ─── Persona ──────────────────────────────────────────────

model Persona {
  id             String   @id @default(cuid())
  userId         String   @unique
  businessName   String?
  industry       String?
  targetAudience String?
  tone           String?
  style          String?
  keywords       String   @default("[]")
  rules          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personas")
}

// ─── Subscription ─────────────────────────────────────────

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  plan               PlanTier
  billingCycle       String
  status             String
  tossBillingKey     String?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

// ─── Notification Setting ─────────────────────────────────

// ─── Payment Log ─────────────────────────────────────────

model PaymentLog {
  id              String    @id @default(cuid())
  userId          String
  subscriptionId  String?
  orderId         String    @unique
  amount          Int
  status          String
  method          String?
  cardInfo        String?
  tossPaymentKey  String?
  failureCode     String?
  failureMsg      String?
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payment_logs")
}

// ─── AI Usage Log ────────────────────────────────────────

model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String
  feature          String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  durationMs       Int?
  isError          Boolean  @default(false)
  errorCode        String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

// ─── Notice ──────────────────────────────────────────────

model Notice {
  id          String    @id @default(cuid())
  title       String
  body        String
  type        String
  targetPlan  String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished])
  @@map("notices")
}

// ─── User Instruction (블로그 작성 지침 프리셋) ─────────────

model UserInstruction {
  id        String   @id @default(cuid())
  userId    String
  name      String   // 지침 이름 (예: "블로그 기본", "SEO 최적화")
  content   String   // 지침 본문
  isDefault Boolean  @default(false) // 기본 지침 여부
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_instructions")
}

// ─── System Config ───────────────────────────────────────

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ─── System Instruction (콘텐츠 타입별 시스템 지침) ──────
// 관리자만 수정 가능. AI 생성 시 항상 기본 적용됨.

enum InstructionContentType {
  ALL           // 모든 콘텐츠에 공통 적용
  CAROUSEL      // 카드뉴스
  BLOG          // 블로그 글
  URL_TO_POST   // URL → 콘텐츠
  BULK_GENERATE // 대량 기획
}

model SystemInstruction {
  id          String                 @id @default(cuid())
  contentType InstructionContentType
  title       String                 // 관리자용 제목
  content     String                 // 실제 시스템 프롬프트 지침
  isActive    Boolean                @default(true)
  updatedBy   String?                // 마지막 수정 관리자 email
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([contentType])            // 타입별 1개
  @@map("system_instructions")
}
